{
  "name": "bc-dev-toolset",
  "displayName": "Business Central Developer's Toolset",
  "description": "Manage your Business Central development environment. Containers, backups, workspaces and more.",
  "version": "1.4.7",
  "publisher": "dam-pav",
  "icon": "assets/bc-dev-toolset.logo.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dam-pav/BC-Dev-Toolset.git",
    "directory": "vscode-extension"
  },
  "scripts": {
    "validate": "node --check extension.js && node --check mcp-server.js && node --check mcp-bridge-identity.js && node --check codex-mcp-config.js && node --test",
    "test": "node --test test",
    "prepare:runtime": "node ./build/prepare-runtime-package.js",
    "package": "npm run prepare:runtime && npx @vscode/vsce package --no-dependencies",
    "publish:marketplace": "npm run prepare:runtime && npx @vscode/vsce publish --no-dependencies",
    "publish:marketplace:pre": "npm run prepare:runtime && npx @vscode/vsce publish --pre-release --no-dependencies"
  },
  "engines": {
    "vscode": "^1.101.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "business central",
    "dynamics 365 business central",
    "al",
    "al language",
    "bc",
    "productivity"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:bcDevToolset.initializeWorkspace",
    "onCommand:bcDevToolset.openLocalSettingsJson",
    "onCommand:bcDevToolset.configureCodexMcp",
    "onCommand:bcDevToolset.disableCodexMcp",
    "onCommand:bcDevToolset.showObjectIdRangeVisualizationData",
    "onCommand:bcDevToolset.showMcpStatus",
    "onCommand:bcDevToolset.runOperation",
    "onMcpCollection:bcDevToolset.operations",
    "onCommand:bcDevToolset.operation.invokeTests",
    "onCommand:bcDevToolset.operation.invokePageScriptTests",
    "onCommand:bcDevToolset.operation.showBcContainerHelperVersions",
    "onCommand:bcDevToolset.operation.initPrerequisites",
    "onCommand:bcDevToolset.operation.updatePowerShell",
    "onCommand:bcDevToolset.operation.clearAppArtifacts",
    "onCommand:bcDevToolset.operation.newDockerContainer",
    "onCommand:bcDevToolset.operation.extractContainerAssemblies",
    "onCommand:bcDevToolset.operation.addTestToolkitToBcContainer",
    "onCommand:bcDevToolset.operation.updateLaunchJson",
    "onCommand:bcDevToolset.operation.updateBcLicenseContainer",
    "onCommand:bcDevToolset.operation.showActiveLicenses",
    "onCommand:bcDevToolset.operation.updateBcContainerServerConfiguration",
    "onCommand:bcDevToolset.operation.backupBcContainerDatabases",
    "onCommand:bcDevToolset.operation.backupBcServiceDatabases",
    "onCommand:bcDevToolset.operation.restoreBcContainerDatabases",
    "onCommand:bcDevToolset.operation.publishDependencies2Docker",
    "onCommand:bcDevToolset.operation.publishDependencies2Test",
    "onCommand:bcDevToolset.operation.publishApps2Docker",
    "onCommand:bcDevToolset.operation.publishApps2Production",
    "onCommand:bcDevToolset.operation.publishApps2Test",
    "onCommand:bcDevToolset.operation.createRuntimePackage",
    "onCommand:bcDevToolset.operation.publishRuntimeApps2Docker",
    "onCommand:bcDevToolset.operation.publishRuntimeApps2Production",
    "onCommand:bcDevToolset.operation.publishRuntimeApps2Test",
    "onCommand:bcDevToolset.operation.unpublishDockerApps",
    "onCommand:bcDevToolset.operation.unpublishTestApps",
    "onCommand:bcDevToolset.operation.prepareObjectIdRangeVisualizationData"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "BC Dev Toolset",
      "properties": {
        "bcDevToolset.toolsetPath": {
          "type": "string",
          "default": "",
          "description": "Central BC-Dev-Toolset installation path. Defaults to %LOCALAPPDATA%\\BC-Dev-Toolset\\toolset on Windows."
        },
        "bcDevToolset.powershellExecutable": {
          "type": "string",
          "default": "pwsh",
          "description": "PowerShell executable used to run BC-Dev-Toolset operations."
        },
        "bcDevToolset.localSettingsPath": {
          "type": "string",
          "default": ".bcdevtoolset/settings.json",
          "description": "Workspace-relative local settings file passed to PowerShell operations when it exists."
        },
        "bcDevToolset.codexMcpIntegration.enabled": {
          "type": "boolean",
          "scope": "machine",
          "default": false,
          "description": "Automatically keep the opted-in BC Dev Toolset entry in the global Codex MCP configuration synchronized with this extension installation. The Configure Codex MCP Integration command enables this setting."
        },
        "bcDevToolset.shortcuts": {
          "type": "string",
          "enum": [
            "None",
            "Desktop",
            "StartMenu"
          ],
          "default": "None",
          "description": "Shortcut mode used for container creation flows."
        },
        "bcDevToolset.hostHelperFolder": {
          "type": "string",
          "default": "C:\\ProgramData\\BcContainerHelper",
          "description": "BcContainerHelper host helper folder used by runtime operations."
        },
        "dam-pav.bcdevtoolset": {
          "type": "object",
          "scope": "resource",
          "default": {
            "selectArtifact": "Latest",
            "executeTestsInContainerName": "",
            "configurations": [
              {
                "name": "sample",
                "serverType": "",
                "targetType": "",
                "server": "",
                "serverInstance": "",
                "container": "",
                "port": "",
                "environmentType": "",
                "environmentName": "",
                "includeTestToolkit": "",
                "tenant": "",
                "authentication": "",
                "bcUser": "",
                "bcPassword": "",
                "network": "",
                "hostIP": "",
                "databaseUser": "",
                "databasePassword": "",
                "remoteUser": "",
                "remotePassword": ""
              }
            ]
          },
          "description": "Shared BC Dev Toolset settings stored in the workspace file.",
          "additionalProperties": true,
          "properties": {
            "selectArtifact": {
              "type": "string",
              "enum": [
                "Latest",
                "First",
                "All",
                "Closest",
                "SecondToLastMajor",
                "Current",
                "NextMinor",
                "NextMajor",
                "Daily",
                "Weekly"
              ],
              "default": "Latest",
              "description": "Business Central artifact selection strategy."
            },
            "executeTestsInContainerName": {
              "type": "string",
              "default": "",
              "description": "Optional container name used by Test operations. If empty and only one Dev container configuration exists, tests run there without backup restore or app deployment. Otherwise Test operations ask which Dev container to use when needed. If the selected container is missing, it is created and an initial SQL backup set is exported before tests continue."
            },
            "sqlBackupPath": {
              "not": {},
              "errorMessage": "Field \"sqlBackupPath\" has moved. Set it inside each relevant \"configurations\" entry.",
              "doNotSuggest": true
            },
            "configurations": {
              "type": "array",
              "description": "Shared Business Central target configurations.",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Configuration display name."
                  },
                  "serverType": {
                    "type": "string",
                    "enum": [
                      "",
                      "Container",
                      "Cloud",
                      "OnPrem"
                    ],
                    "description": "Business Central server type."
                  },
                  "targetType": {
                    "type": "string",
                    "enum": [
                      "",
                      "Dev",
                      "Test",
                      "Production"
                    ],
                    "description": "Target environment role."
                  },
                  "autoUpdateLaunchJson": {
                    "type": "boolean",
                    "description": "Optional override for whether update launch.json operations include this configuration. Applies to all server types. When omitted, the effective value is true for Dev targets and false otherwise."
                  },
                  "databaseUser": {
                    "type": "string",
                    "description": "Optional SQL user for database operations."
                  },
                  "databasePassword": {
                    "type": "string",
                    "description": "Optional SQL password for database operations."
                  },
                  "remoteUser": {
                    "type": "string",
                    "description": "Optional PowerShell remoting user."
                  },
                  "remotePassword": {
                    "type": "string",
                    "description": "Optional PowerShell remoting password."
                  },
                  "serverConfiguration": {
                    "type": "array",
                    "description": "Additional Business Central server configuration entries.",
                    "items": {
                      "type": "object",
                      "properties": {
                        "KeyName": {
                          "type": "string",
                          "description": "Server configuration key."
                        },
                        "KeyValue": {
                          "type": [
                            "string",
                            "number",
                            "boolean"
                          ],
                          "description": "Server configuration value."
                        }
                      }
                    }
                  }
                },
                "allOf": [
                  {
                    "if": {
                      "properties": {
                        "serverType": {
                          "const": "Container"
                        }
                      },
                      "required": [
                        "serverType"
                      ]
                    },
                    "then": {
                      "properties": {
                        "container": {
                          "type": "string",
                          "description": "Docker container name for Container targets."
                        },
                        "environmentType": {
                          "type": "string",
                          "enum": [
                            "",
                            "Sandbox",
                            "OnPrem"
                          ],
                          "description": "Business Central environment type."
                        },
                        "includeTestToolkit": {
                          "type": [
                            "string",
                            "boolean"
                          ],
                          "description": "Whether container environments should include the test toolkit."
                        },
                        "authentication": {
                          "type": "string",
                          "enum": [
                            "",
                            "UserPassword",
                            "Windows",
                            "AAD"
                          ],
                          "description": "Authentication mode."
                        },
                        "bcUser": {
                          "type": "string",
                          "description": "Business Central service user name."
                        },
                        "bcPassword": {
                          "type": "string",
                          "description": "Business Central service password."
                        },
                        "sqlBackupPath": {
                          "type": "string",
                          "description": "Path used for SQL backup files for this Container configuration."
                        },
                        "admin": {
                          "type": "string",
                          "description": "Obsolete. Use \"bcUser\" instead.",
                          "deprecated": true,
                          "deprecationMessage": "Field \"admin\" is obsolete and will be removed in the next major release. Use \"bcUser\" instead.",
                          "markdownDeprecationMessage": "Field `admin` is obsolete and will be removed in the next major release. Use `bcUser` instead."
                        },
                        "password": {
                          "type": "string",
                          "description": "Obsolete. Use \"bcPassword\" instead.",
                          "deprecated": true,
                          "deprecationMessage": "Field \"password\" is obsolete and will be removed in the next major release. Use \"bcPassword\" instead.",
                          "markdownDeprecationMessage": "Field `password` is obsolete and will be removed in the next major release. Use `bcPassword` instead."
                        },
                        "network": {
                          "anyOf": [
                            {
                              "type": "string",
                              "enum": [
                                "",
                                "NAT",
                                "nat",
                                "transparent",
                                "l2bridge",
                                "l2tunnel",
                                "overlay",
                                "none"
                              ]
                            },
                            {
                              "type": "string"
                            }
                          ],
                          "description": "Optional Docker network passed to New-BcContainer for Container targets. Known network names are verified and missing creatable networks are created with the matching Docker driver; custom network names are allowed and are not managed by the toolset."
                        },
                        "hostIP": {
                          "type": "string",
                          "description": "Optional host.containerhelper.internal IP address passed to New-BcContainer."
                        },
                        "updateHosts": {
                          "type": [
                            "string",
                            "boolean"
                          ],
                          "enum": [
                            "",
                            "true",
                            "false",
                            true,
                            false
                          ],
                          "default": true,
                          "description": "Whether New-BcContainer should update the host machine's hosts file. Defaults to true when omitted."
                        },
                        "macAddress": {
                          "type": "string",
                          "description": "Optional container MAC address passed to New-BcContainer. Use only with a transparent network."
                        },
                        "IP": {
                          "type": "string",
                          "description": "Optional static container IP address passed to New-BcContainer. Use only with a transparent network; leave empty when the network should assign an address."
                        },
                        "dns": {
                          "anyOf": [
                            {
                              "type": "string",
                              "enum": [
                                "",
                                "HostDNS"
                              ]
                            },
                            {
                              "type": "string"
                            }
                          ],
                          "description": "Optional DNS value passed to New-BcContainer. Use only with a transparent network. BcContainerHelper recognizes HostDNS; explicit DNS server values are also allowed."
                        },
                        "autoExtractAssemblies": {
                          "type": "boolean",
                          "default": false,
                          "description": "Whether Service and .NET assemblies are extracted automatically after this container is built. Manual extraction ignores this setting."
                        },
                        "autoRestoreBackup": {
                          "type": "boolean",
                          "default": true,
                          "description": "Whether Create Docker container and Test operations automatically restore a compatible SQL backup set from sqlBackupPath. Defaults to true when omitted. Manual restore operations ignore this setting."
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "properties": {
                        "serverType": {
                          "const": "Cloud"
                        }
                      },
                      "required": [
                        "serverType"
                      ]
                    },
                    "then": {
                      "properties": {
                        "environmentType": {
                          "type": "string",
                          "enum": [
                            "",
                            "Sandbox",
                            "OnPrem"
                          ],
                          "description": "Business Central environment type."
                        },
                        "environmentName": {
                          "type": "string",
                          "description": "Cloud environment name."
                        },
                        "tenant": {
                          "type": "string",
                          "description": "Tenant identifier for Cloud or OnPrem targets."
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "properties": {
                        "serverType": {
                          "const": "OnPrem"
                        }
                      },
                      "required": [
                        "serverType"
                      ]
                    },
                    "then": {
                      "properties": {
                        "server": {
                          "type": "string",
                          "description": "Server name for OnPrem targets."
                        },
                        "serverInstance": {
                          "type": "string",
                          "description": "Server instance for OnPrem targets."
                        },
                        "port": {
                          "type": "string",
                          "description": "Port for OnPrem targets."
                        },
                        "tenant": {
                          "type": "string",
                          "description": "Tenant identifier for Cloud or OnPrem targets."
                        },
                        "authentication": {
                          "type": "string",
                          "enum": [
                            "",
                            "UserPassword",
                            "Windows",
                            "AAD"
                          ],
                          "description": "Authentication mode."
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "serverType"
                      ],
                      "not": {
                        "properties": {
                          "serverType": {
                            "const": "OnPrem"
                          }
                        }
                      }
                    },
                    "then": {
                      "properties": {
                        "server": {
                          "not": {},
                          "errorMessage": "Field \"server\" is not valid when \"serverType\" is not \"OnPrem\".",
                          "doNotSuggest": true
                        },
                        "serverInstance": {
                          "not": {},
                          "errorMessage": "Field \"serverInstance\" is not valid when \"serverType\" is not \"OnPrem\".",
                          "doNotSuggest": true
                        },
                        "port": {
                          "not": {},
                          "errorMessage": "Field \"port\" is not valid when \"serverType\" is not \"OnPrem\".",
                          "doNotSuggest": true
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "serverType"
                      ],
                      "not": {
                        "properties": {
                          "serverType": {
                            "const": "Container"
                          }
                        }
                      }
                    },
                    "then": {
                      "properties": {
                        "container": {
                          "not": {},
                          "errorMessage": "Field \"container\" is not valid when \"serverType\" is not \"Container\".",
                          "doNotSuggest": true
                        },
                        "includeTestToolkit": {
                          "not": {},
                          "errorMessage": "Field \"includeTestToolkit\" is not valid when \"serverType\" is not \"Container\".",
                          "doNotSuggest": true
                        },
                        "bcUser": {
                          "not": {},
                          "errorMessage": "Field \"bcUser\" is not valid when \"serverType\" is not \"Container\".",
                          "doNotSuggest": true
                        },
                        "bcPassword": {
                          "not": {},
                          "errorMessage": "Field \"bcPassword\" is not valid when \"serverType\" is not \"Container\".",
                          "doNotSuggest": true
                        },
                        "sqlBackupPath": {
                          "not": {},
                          "errorMessage": "Field \"sqlBackupPath\" is not valid when \"serverType\" is not \"Container\".",
                          "doNotSuggest": true
                        },
                        "admin": {
                          "not": {},
                          "errorMessage": "Field \"admin\" is not valid when \"serverType\" is not \"Container\".",
                          "doNotSuggest": true
                        },
                        "password": {
                          "not": {},
                          "errorMessage": "Field \"password\" is not valid when \"serverType\" is not \"Container\".",
                          "doNotSuggest": true
                        },
                        "autoExtractAssemblies": {
                          "not": {},
                          "errorMessage": "Field \"autoExtractAssemblies\" is not valid when \"serverType\" is not \"Container\".",
                          "doNotSuggest": true
                        },
                        "autoRestoreBackup": {
                          "not": {},
                          "errorMessage": "Field \"autoRestoreBackup\" is not valid when \"serverType\" is not \"Container\".",
                          "doNotSuggest": true
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "serverType"
                      ],
                      "not": {
                        "properties": {
                          "serverType": {
                            "enum": [
                              "Container",
                              "Cloud"
                            ]
                          }
                        }
                      }
                    },
                    "then": {
                      "properties": {
                        "environmentType": {
                          "not": {},
                          "errorMessage": "Field \"environmentType\" is not valid when \"serverType\" is not \"Container\" or \"Cloud\".",
                          "doNotSuggest": true
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "serverType"
                      ],
                      "not": {
                        "properties": {
                          "serverType": {
                            "const": "Cloud"
                          }
                        }
                      }
                    },
                    "then": {
                      "properties": {
                        "environmentName": {
                          "not": {},
                          "errorMessage": "Field \"environmentName\" is not valid when \"serverType\" is not \"Cloud\".",
                          "doNotSuggest": true
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "serverType"
                      ],
                      "not": {
                        "properties": {
                          "serverType": {
                            "enum": [
                              "Cloud",
                              "OnPrem"
                            ]
                          }
                        }
                      }
                    },
                    "then": {
                      "properties": {
                        "tenant": {
                          "not": {},
                          "errorMessage": "Field \"tenant\" is not valid when \"serverType\" is not \"Cloud\" or \"OnPrem\".",
                          "doNotSuggest": true
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "serverType"
                      ],
                      "not": {
                        "properties": {
                          "serverType": {
                            "enum": [
                              "Container",
                              "OnPrem"
                            ]
                          }
                        }
                      }
                    },
                    "then": {
                      "properties": {
                        "authentication": {
                          "not": {},
                          "errorMessage": "Field \"authentication\" is not valid when \"serverType\" is not \"Container\" or \"OnPrem\".",
                          "doNotSuggest": true
                        }
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      }
    },
    "jsonValidation": [
      {
        "fileMatch": [
          "**/.bcdevtoolset/settings.json"
        ],
        "url": "./schemas/bcdevtoolset-settings.schema.json"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "bcDevToolset.operations",
        "label": "BC Dev Toolset Operations"
      }
    ],
    "chatInstructions": [
      {
        "path": "./assets/prompts/bc-dev-toolset-instructions.md",
        "when": "true"
      }
    ],
    "commands": [
      {
        "command": "bcDevToolset.initializeWorkspace",
        "title": "BC Dev Toolset: Initialize Workspace"
      },
      {
        "command": "bcDevToolset.openLocalSettingsJson",
        "title": "BC Dev Toolset: Open Local Settings (JSON)"
      },
      {
        "command": "bcDevToolset.configureCodexMcp",
        "title": "BC Dev Toolset: Configure Codex MCP Integration"
      },
      {
        "command": "bcDevToolset.disableCodexMcp",
        "title": "BC Dev Toolset: Disable Codex MCP Integration"
      },
      {
        "command": "bcDevToolset.showObjectIdRangeVisualizationData",
        "title": "BC Dev Toolset: Show object id range visualization data"
      },
      {
        "command": "bcDevToolset.runOperation",
        "title": "BC Dev Toolset: Show Operations List"
      },
      {
        "command": "bcDevToolset.showMcpStatus",
        "title": "BC Dev Toolset: Show MCP Status"
      },
      {
        "command": "bcDevToolset.operation.invokeTests",
        "title": "BC Dev Toolset: Run AL test tool tests"
      },
      {
        "command": "bcDevToolset.operation.invokePageScriptTests",
        "title": "BC Dev Toolset: Run page script tests"
      },
      {
        "command": "bcDevToolset.operation.showBcContainerHelperVersions",
        "title": "BC Dev Toolset: Show BcContainerHelper versions (installed and available)"
      },
      {
        "command": "bcDevToolset.operation.initPrerequisites",
        "title": "BC Dev Toolset: Install prerequisites"
      },
      {
        "command": "bcDevToolset.operation.updatePowerShell",
        "title": "BC Dev Toolset: Update Microsoft PowerShell"
      },
      {
        "command": "bcDevToolset.operation.clearAppArtifacts",
        "title": "BC Dev Toolset: Clear App and translation artifacts"
      },
      {
        "command": "bcDevToolset.operation.newDockerContainer",
        "title": "BC Dev Toolset: Create/Overwrite Docker container based on the workspace app.json application version"
      },
      {
        "command": "bcDevToolset.operation.extractContainerAssemblies",
        "title": "BC Dev Toolset: Extract assembly probing paths from Docker container"
      },
      {
        "command": "bcDevToolset.operation.addTestToolkitToBcContainer",
        "title": "BC Dev Toolset: Add Test Toolkit to existing container"
      },
      {
        "command": "bcDevToolset.operation.updateLaunchJson",
        "title": "BC Dev Toolset: Update launch.json files in all apps in the workspace"
      },
      {
        "command": "bcDevToolset.operation.updateBcLicenseContainer",
        "title": "BC Dev Toolset: Update license files in all containers"
      },
      {
        "command": "bcDevToolset.operation.showActiveLicenses",
        "title": "BC Dev Toolset: Show active licenses"
      },
      {
        "command": "bcDevToolset.operation.updateBcContainerServerConfiguration",
        "title": "BC Dev Toolset: Update server configuration in all containers"
      },
      {
        "command": "bcDevToolset.operation.backupBcContainerDatabases",
        "title": "BC Dev Toolset: Create and export SQL backup set from Docker container"
      },
      {
        "command": "bcDevToolset.operation.backupBcServiceDatabases",
        "title": "BC Dev Toolset: Create and export SQL backup set from BC service SQL Server"
      },
      {
        "command": "bcDevToolset.operation.restoreBcContainerDatabases",
        "title": "BC Dev Toolset: Restore SQL backup set to Docker container"
      },
      {
        "command": "bcDevToolset.operation.publishDependencies2Docker",
        "title": "BC Dev Toolset: Publish dependencies from the configuration to the existing container"
      },
      {
        "command": "bcDevToolset.operation.publishDependencies2Test",
        "title": "BC Dev Toolset: Publish dependencies from the configuration to test environments"
      },
      {
        "command": "bcDevToolset.operation.publishApps2Docker",
        "title": "BC Dev Toolset: Publish all apps in the workspace to Docker container"
      },
      {
        "command": "bcDevToolset.operation.publishApps2Production",
        "title": "BC Dev Toolset: Publish all apps in the workspace to production environments"
      },
      {
        "command": "bcDevToolset.operation.publishApps2Test",
        "title": "BC Dev Toolset: Publish all apps in the workspace to test environments"
      },
      {
        "command": "bcDevToolset.operation.createRuntimePackage",
        "title": "BC Dev Toolset: Create deployment runtime packages for all apps in the workspace (not compile/build validation)"
      },
      {
        "command": "bcDevToolset.operation.publishRuntimeApps2Docker",
        "title": "BC Dev Toolset: Publish runtime packages (stored) to the existing container"
      },
      {
        "command": "bcDevToolset.operation.publishRuntimeApps2Production",
        "title": "BC Dev Toolset: Publish runtime packages (stored) to production environments"
      },
